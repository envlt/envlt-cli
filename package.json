{
  "name": "envlt",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "envlt": "./dist/bin/envlt.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --import tsx --experimental-vm-modules --test 'src/**/*.test.ts' 'tests/**/*.test.ts'",
    "test:coverage": "c8 npm test",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "precommit": "lint-staged",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "chalk": "5.3.0",
    "commander": "12.1.0",
    "inquirer": "9.3.7"
  },
  "devDependencies": {
    "@types/node": "22.13.10",
    "@types/sinon": "17.0.3",
    "@typescript-eslint/eslint-plugin": "8.25.0",
    "@typescript-eslint/parser": "8.25.0",
    "c8": "10.1.3",
    "eslint": "9.21.0",
    "husky": "9.1.7",
    "lint-staged": "15.5.0",
    "prettier": "3.5.3",
    "sinon": "19.0.2",
    "tsx": "4.19.3",
    "typescript": "5.8.2"
  }
}
